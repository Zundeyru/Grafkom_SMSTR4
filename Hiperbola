-- =============================================
-- FUNGSI KALKULASI
-- =============================================
local function hitungKalkulasi(a, b, delta)
	delta = math.max(0.01, delta)
	local titikKanan = 0
	local titikKiri  = 0

	local t = -math.pi/2 + delta
	while t < math.pi/2 - delta do
		titikKanan = titikKanan + 1
		t = t + delta
	end
	t = math.pi/2 + delta
	while t < 3 * math.pi/2 - delta do
		titikKiri = titikKiri + 1
		t = t + delta
	end

	local asimtot = b / a
	local eksentrisitas = math.sqrt(a^2 + b^2) / a

	return {
		titikKanan = titikKanan,
		titikKiri  = titikKiri,
		total      = titikKanan + titikKiri,
		asimtot    = string.format("±%.2f", asimtot),
		eksentrisitas = string.format("%.3f", eksentrisitas),
	}
end

local function tampilHasil(a1, b1, d1, a2, b2, d2)
	local h1 = hitungKalkulasi(a1, b1, d1)
	local h2 = hitungKalkulasi(a2, b2, d2)

	hasilLabel.Text =
		"📊 H1: " .. h1.total .. " titik | asimtot=" .. h1.asimtot .. " | e=" .. h1.eksentrisitas .. "\n" ..
		"📊 H2: " .. h2.total .. " titik | asimtot=" .. h2.asimtot .. " | e=" .. h2.eksentrisitas

	TweenService:Create(hasilPanel,
		TweenInfo.new(0.3, Enum.EasingStyle.Quad),
		{ Size = UDim2.new(0.9, 0, 0, 50) }
	):Play()
end


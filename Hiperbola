	local a2 = tonumber(inputs2.a.Text) or 5
	local b2 = tonumber(inputs2.b.Text) or 3
	local d2 = tonumber(inputs2.d.Text) or 0.06

	if a1 <= 0 or b1 <= 0 or a2 <= 0 or b2 <= 0 then
		hasilLabel.Text = "⚠️ a dan b harus > 0!"
		TweenService:Create(hasilPanel,
			TweenInfo.new(0.3),
			{ Size = UDim2.new(0.9, 0, 0, 25) }
		):Play()
		return
	end

	-- Tampilkan kalkulasi
	tampilHasil(a1, b1, d1, a2, b2, d2)

	-- Kirim ke server
	local params = {
		a1 = a1, b1 = b1, d1 = d1,
		a2 = a2, b2 = b2, d2 = d2,
	}
	generateEvent:FireServer(params)

	-- Efek tombol
	tombolGenerate.Text = "⏳ Generating..."
	tombolGenerate.BackgroundColor3 = Color3.fromRGB(0, 80, 160)
	task.delay(1.5, function()
		tombolGenerate.Text = "🚀 GENERATE"
		tombolGenerate.BackgroundColor3 = Color3.fromRGB(0, 140, 255)
	end)
end)


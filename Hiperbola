-- =============================================
-- FUNGSI : Buat panel input untuk 1 hiperbola
-- =============================================
local function buatPanel(nama, warna, yOffset, defaults)
	local sub = Instance.new("Frame")
	sub.Name             = nama .. "Panel"
	sub.Size             = UDim2.new(0.9, 0, 0, 105)
	sub.Position         = UDim2.new(0.05, 0, 0, yOffset)
	sub.BackgroundColor3 = Color3.fromRGB(25, 35, 60)
	sub.BorderSizePixel  = 0
	sub.Parent           = panel

	local subCorner = Instance.new("UICorner")
	subCorner.CornerRadius = UDim.new(0, 8)
	subCorner.Parent = sub

	-- Label nama
	local label = Instance.new("TextLabel")
	label.Size             = UDim2.new(1, 0, 0, 22)
	label.BackgroundColor3 = warna
	label.BorderSizePixel  = 0
	label.Text             = nama
	label.TextColor3       = Color3.new(1, 1, 1)
	label.Font             = Enum.Font.GothamBold
	label.TextScaled       = true
	label.Parent           = sub

	local labelCorner = Instance.new("UICorner")
	labelCorner.CornerRadius = UDim.new(0, 8)
	labelCorner.Parent = label

	-- Input fields
	local inputs = {}
	local fields = {
		{key = "a", label = "a (transversal):", default = defaults.a},
		{key = "b", label = "b (konjugasi):",  default = defaults.b},
		{key = "d", label = "delta (Δθ):",     default = defaults.d},
	}

	for idx, field in ipairs(fields) do
		local row = Instance.new("Frame")
		row.Name             = "Row_" .. field.key
		row.Size             = UDim2.new(1, -10, 0, 24)
		row.Position         = UDim2.new(0, 5, 0, 24 + (idx - 1) * 26)
		row.BackgroundTransparency = 1
		row.Parent           = sub

		local fieldLabel = Instance.new("TextLabel")
		fieldLabel.Size             = UDim2.new(0.55, 0, 1, 0)
		fieldLabel.BackgroundTransparency = 1
		fieldLabel.Text             = field.label
		fieldLabel.TextColor3       = Color3.fromRGB(200, 200, 200)
		fieldLabel.Font             = Enum.Font.Gotham
		fieldLabel.TextScaled       = true
		fieldLabel.TextXAlignment   = Enum.TextXAlignment.Left
		fieldLabel.Parent           = row

		local textBox = Instance.new("TextBox")
		textBox.Name               = field.key .. "Input"
		textBox.Size               = UDim2.new(0.4, 0, 0.85, 0)
		textBox.Position           = UDim2.new(0.58, 0, 0.075, 0)
		textBox.BackgroundColor3   = Color3.fromRGB(20, 40, 80)
		textBox.BorderSizePixel    = 0
		textBox.Text               = tostring(field.default)
		textBox.TextColor3         = Color3.new(1, 1, 1)
		textBox.Font               = Enum.Font.GothamBold
		textBox.TextScaled         = true
		textBox.ClearTextOnFocus   = false
		textBox.Parent             = row

		local tbCorner = Instance.new("UICorner")
		tbCorner.CornerRadius = UDim.new(0, 6)
		tbCorner.Parent = textBox

		inputs[field.key] = textBox
	end

	return inputs
end


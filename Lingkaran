-- ============ FUNGSI BANTU: BUAT INPUT DENGAN TOMBOL +/- ============
local function buatInput(parent, namaLabel, defaultValue, stepNaik)
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -10, 0, 16)
	label.Position = UDim2.new(0, 5, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = namaLabel
	label.TextColor3 = Color3.new(1, 1, 1)
	label.TextSize = 13
	label.Parent = parent

	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, -10, 0, 28)
	row.Position = UDim2.new(0, 5, 0, 0)
	row.BackgroundTransparency = 1
	row.Parent = parent

	local btnMin = Instance.new("TextButton")
	btnMin.Size = UDim2.new(0, 26, 1, 0)
	btnMin.Text = "-"
	btnMin.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
	btnMin.TextColor3 = Color3.new(1, 1, 1)
	btnMin.Parent = row

	local textBox = Instance.new("TextBox")
	textBox.Size = UDim2.new(1, -60, 1, 0)
	textBox.Position = UDim2.new(0, 30, 0, 0)
	textBox.Text = tostring(defaultValue)
	textBox.TextSize = 13
	textBox.Parent = row

	local btnPlus = Instance.new("TextButton")
	btnPlus.Size = UDim2.new(0, 26, 1, 0)
	btnPlus.Position = UDim2.new(1, -26, 0, 0)
	btnPlus.Text = "+"
	btnPlus.BackgroundColor3 = Color3.fromRGB(60, 170, 80)
	btnPlus.TextColor3 = Color3.new(1, 1, 1)
	btnPlus.Parent = row

	btnPlus.MouseButton1Click:Connect(function()
		local nilai = tonumber(textBox.Text) or 0
		textBox.Text = tostring(nilai + stepNaik)
	end)
	btnMin.MouseButton1Click:Connect(function()
		local nilai = tonumber(textBox.Text) or 0
		textBox.Text = tostring(nilai - stepNaik)
	end)

	return textBox
end

-- ============ FUNGSI BANTU: GAMBAR GARIS ANTAR 2 TITIK ============
local function buatGaris(posA, posB, folder, warna)
	local jarak = (posA - posB).Magnitude
	local garis = Instance.new("Part")
	garis.Anchored = true
	garis.CanCollide = false
	garis.Material = Enum.Material.Neon
	garis.BrickColor = warna
	garis.Size = Vector3.new(0.2, 0.2, jarak)
	garis.CFrame = CFrame.new(posA, posB) * CFrame.new(0, 0, -jarak / 2)
	garis.Parent = folder
end

-- ============ FUNGSI UTAMA: GAMBAR LINGKARAN + GARIS PENGHUBUNG ============
local function gambarLingkaran(xc, yc, r, dTheta, ukuran, namaFolder, warnaTitik, warnaGaris)
	local folderLama = workspace:FindFirstChild(namaFolder)
	if folderLama then
		folderLama:Destroy()
	end

	local folder = Instance.new("Folder")
	folder.Name = namaFolder
	folder.Parent = workspace

	local thetaAkhir = 2 * math.pi
	local titikSebelumnya = nil
	local titikPertama = nil
	local titikTerakhir = nil

	print("=== Mulai Membangkitkan " .. namaFolder .. " ===")

	-- ITERASI: titik terakhir dipaksa tepat di theta = 2π
	local jumlahTitik = math.floor(thetaAkhir / dTheta)
	for i = 0, jumlahTitik do
		local theta = i * dTheta
		if theta > thetaAkhir then
			theta = thetaAkhir
		end

		-- KALKULASI
		local x = xc + r * math.cos(theta)
		local z = yc + r * math.sin(theta)
		local posTitik = Vector3.new(x, 2, z)

		-- RENDERING TITIK
		local part = Instance.new("Part")
		part.Shape = Enum.PartType.Ball
		part.Anchored = true
		part.CanCollide = false
		part.Parent = folder

		if theta == 0 then
			part.Size = Vector3.new(ukuran * 2, ukuran * 2, ukuran * 2)
			part.BrickColor = BrickColor.new("Bright red")
			print(">>> TITIK AWAL: θ=0.00 | x=" .. string.format("%.2f", x) .. " | z=" .. string.format("%.2f", z))
			titikPertama = posTitik
		elseif theta == thetaAkhir then
			part.Size = Vector3.new(ukuran * 2, ukuran * 2, ukuran * 2)
			part.BrickColor = BrickColor.new("Bright green")
			print(">>> TITIK AKHIR: θ=" .. string.format("%.2f", theta) .. " | x=" .. string.format("%.2f", x) .. " | z=" .. string.format("%.2f", z))
		else
			part.Size = Vector3.new(ukuran, ukuran, ukuran)
			part.BrickColor = warnaTitik
			print(string.format("θ=%.2f | x=%.2f | z=%.2f", theta, x, z))
		end

		part.Position = posTitik

		-- RENDERING GARIS PENGHUBUNG (antar titik berurutan)
		if titikSebelumnya ~= nil then
			buatGaris(titikSebelumnya, posTitik, folder, warnaGaris)
		end
		titikSebelumnya = posTitik
		titikTerakhir = posTitik

		task.wait(0.03)
	end

	-- Garis penutup: titik akhir (hijau) -> titik awal (merah)
	if titikPertama ~= nil and titikTerakhir ~= nil then
		buatGaris(titikTerakhir, titikPertama, folder, warnaGaris)
		print(">>> Garis penutup ditambahkan (titik akhir → titik awal)")
	end

	print("=== " .. namaFolder .. " Selesai Digambar! ===")
end

